<UserControl x:Class="iiCourseWPF.Controls.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="220">
    <UserControl.Resources>
        <!-- 菜单按钮基础样式 -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="0"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                BorderThickness="0" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard Storyboard="{StaticResource MenuItemHoverAnimation}"/>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Border" 
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="#FFF5EB" Duration="0:0:0.2">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard Storyboard="{StaticResource MenuItemLeaveAnimation}"/>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Border" 
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="Transparent" Duration="0:0:0.2">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFE8D6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 激活状态菜单按钮样式 -->
        <Style x:Key="ActiveMenuButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#FFF5EB"/>
            <Setter Property="Foreground" Value="#FF6B35"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                BorderThickness="0">
                            <Grid>
                                <Border Width="4" Background="#FF6B35" 
                                        HorizontalAlignment="Left" CornerRadius="0,2,2,0"/>
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                VerticalAlignment="Center" Margin="20,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFE8D6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 图标样式 -->
        <Style x:Key="MenuIconStyle" TargetType="Path">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Fill" Value="#7F8C8D"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ActiveMenuIconStyle" TargetType="Path" BasedOn="{StaticResource MenuIconStyle}">
            <Setter Property="Fill" Value="#FF6B35"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#FAFAFA" BorderBrush="#EEEEEE" BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo区域 -->
            <Border Grid.Row="0" Padding="16,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF6B35" Offset="0"/>
                        <GradientStop Color="#FF8555" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="iiCourse" FontSize="20" FontWeight="Bold"
                              Foreground="White" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 菜单按钮区域 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,6">
                <StackPanel>
                    <Button x:Name="BtnUserInfo" Style="{StaticResource MenuButtonStyle}" 
                            Click="OnMenuClick" Tag="UserInfo">
                        <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                            <Path Style="{StaticResource MenuIconStyle}" Data="{StaticResource UserIcon}"/>
                            <TextBlock Text="用户信息" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnClassSchedule" Style="{StaticResource MenuButtonStyle}" 
                            Click="OnMenuClick" Tag="ClassSchedule">
                        <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                            <Path Style="{StaticResource MenuIconStyle}" Data="{StaticResource CalendarIcon}"/>
                            <TextBlock Text="课程表" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnScore" Style="{StaticResource MenuButtonStyle}" 
                            Click="OnMenuClick" Tag="Score">
                        <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                            <Path Style="{StaticResource MenuIconStyle}" Data="{StaticResource ChartIcon}"/>
                            <TextBlock Text="成绩查询" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnSpareClassroom" Style="{StaticResource MenuButtonStyle}" 
                            Click="OnMenuClick" Tag="SpareClassroom">
                        <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                            <Path Style="{StaticResource MenuIconStyle}" Data="{StaticResource SchoolIcon}"/>
                            <TextBlock Text="空教室查询" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnCardInfo" Style="{StaticResource MenuButtonStyle}" 
                            Click="OnMenuClick" Tag="CardInfo">
                        <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                            <Path Style="{StaticResource MenuIconStyle}" Data="{StaticResource CardIcon}"/>
                            <TextBlock Text="一卡通信息" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnEvaluation" Style="{StaticResource MenuButtonStyle}" 
                            Click="OnMenuClick" Tag="Evaluation">
                        <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                            <Path Style="{StaticResource MenuIconStyle}" Data="{StaticResource StarIcon}"/>
                            <TextBlock Text="学生评教" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Margin="12,10" Background="#E0E0E0" Height="1"/>

                    <Button x:Name="BtnSettings" Style="{StaticResource MenuButtonStyle}" 
                            Click="OnMenuClick" Tag="Settings">
                        <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                            <Path Style="{StaticResource MenuIconStyle}" Data="{StaticResource SettingsIcon}"/>
                            <TextBlock Text="设置" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnPrivacy" Style="{StaticResource MenuButtonStyle}" 
                            Click="OnMenuClick" Tag="Privacy">
                        <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                            <Path Style="{StaticResource MenuIconStyle}" Data="{StaticResource PrivacyIcon}"/>
                            <TextBlock Text="隐私政策" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部状态 -->
            <Border Grid.Row="2" Background="#F5F5F5" Padding="16,14" 
                    BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Path Width="12" Height="12" Data="{StaticResource UserIcon}" 
                              Fill="#7F8C8D" Stretch="Uniform" Margin="0,0,6,0"
                              VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="未登录" 
                                  FontSize="11" Foreground="#7F8C8D" 
                                  TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="UserNameText" Text="" 
                              FontSize="10" Foreground="#95A5A6" 
                              Margin="18,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>