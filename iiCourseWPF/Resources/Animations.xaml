<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- 缓动函数定义 -->
    <CubicEase x:Key="EaseOutCubic" EasingMode="EaseOut"/>
    <QuadraticEase x:Key="EaseOutQuad" EasingMode="EaseOut"/>
    <CubicEase x:Key="EaseInOutCubic" EasingMode="EaseInOut"/>
    
    <!-- 通用动画时长 -->
    <Duration x:Key="AnimationDurationFast">0:0:0.15</Duration>
    <Duration x:Key="AnimationDurationNormal">0:0:0.25</Duration>
    <Duration x:Key="AnimationDurationSlow">0:0:0.4</Duration>
    
    <!-- 页面切换动画 - 淡入上滑 -->
    <Storyboard x:Key="PageEnterAnimation">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="{StaticResource AnimationDurationSlow}"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         From="20" To="0"
                         Duration="{StaticResource AnimationDurationSlow}"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    
    <!-- 页面退出动画 - 淡出 -->
    <Storyboard x:Key="PageExitAnimation">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="1" To="0"
                         Duration="{StaticResource AnimationDurationNormal}"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    
    <!-- 卡片依次出现动画 -->
    <Storyboard x:Key="CardAppearAnimation">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="{StaticResource AnimationDurationNormal}"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         From="15" To="0"
                         Duration="{StaticResource AnimationDurationNormal}"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    
    <!-- 按钮按下动画 -->
    <Storyboard x:Key="ButtonPressAnimation">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         To="0.98"
                         Duration="{StaticResource AnimationDurationFast}"
                         EasingFunction="{StaticResource EaseOutQuad}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         To="0.98"
                         Duration="{StaticResource AnimationDurationFast}"
                         EasingFunction="{StaticResource EaseOutQuad}"/>
    </Storyboard>
    
    <!-- 按钮释放动画 -->
    <Storyboard x:Key="ButtonReleaseAnimation">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         To="1"
                         Duration="{StaticResource AnimationDurationFast}"
                         EasingFunction="{StaticResource EaseOutQuad}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         To="1"
                         Duration="{StaticResource AnimationDurationFast}"
                         EasingFunction="{StaticResource EaseOutQuad}"/>
    </Storyboard>
    
    <!-- 输入框聚焦发光动画 -->
    <Storyboard x:Key="InputFocusAnimation">
        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                        To="#FF6B35"
                        Duration="{StaticResource AnimationDurationNormal}"
                        EasingFunction="{StaticResource EaseOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                         To="0.15"
                         Duration="{StaticResource AnimationDurationNormal}"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    
    <!-- 输入框失焦动画 -->
    <Storyboard x:Key="InputBlurAnimation">
        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                        To="#E8E8E8"
                        Duration="{StaticResource AnimationDurationNormal}"
                        EasingFunction="{StaticResource EaseOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                         To="0"
                         Duration="{StaticResource AnimationDurationNormal}"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    
    <!-- 侧边栏菜单项悬停动画 -->
    <Storyboard x:Key="MenuItemHoverAnimation">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                         To="4"
                         Duration="{StaticResource AnimationDurationFast}"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    
    <!-- 侧边栏菜单项离开动画 -->
    <Storyboard x:Key="MenuItemLeaveAnimation">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                         To="0"
                         Duration="{StaticResource AnimationDurationFast}"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    
    <!-- 加载骨架屏 Shimmer 动画 -->
    <Storyboard x:Key="ShimmerAnimation" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                         From="-200" To="400"
                         Duration="0:0:1.5"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    
    <!-- 脉冲动画（用于通知点等） -->
    <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever" AutoReverse="True">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         From="1" To="1.2"
                         Duration="0:0:0.8"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         From="1" To="1.2"
                         Duration="0:0:0.8"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="1" To="0.6"
                         Duration="0:0:0.8"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
    </Storyboard>
    
    <!-- 旋转加载动画 -->
    <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                         From="0" To="360"
                         Duration="0:0:1"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    
    <!-- 加载动画控件样式 -->
    <Style x:Key="LoadingSpinnerStyle" TargetType="Control">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Control">
                    <Grid>
                        <Path Data="M20,2 A18,18 0 1,1 2,20" 
                              Stroke="#FF6B35" 
                              StrokeThickness="3"
                              Fill="Transparent"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Path.RenderTransform>
                            <Path.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard Storyboard="{StaticResource SpinAnimation}"/>
                                </EventTrigger>
                            </Path.Triggers>
                        </Path>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- 骨架屏样式 -->
    <Style x:Key="SkeletonStyle" TargetType="Border">
        <Setter Property="Background" Value="#EEEEEE"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="OpacityMask">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="White" Offset="0.5"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>
