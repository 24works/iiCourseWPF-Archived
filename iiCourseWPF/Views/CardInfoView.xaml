<UserControl x:Class="iiCourseWPF.Views.CardInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="600">
    <Grid Background="#FFF8F0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 头部标题 -->
                <Border Style="{StaticResource PageHeaderStyle}">
                    <StackPanel>
                        <TextBlock Text="一卡通信息" FontSize="26" FontWeight="Bold" 
                                  Foreground="White" Margin="0,0,0,6"/>
                        <TextBlock Text="查看您的校园卡余额和消费记录" FontSize="13" 
                                  Foreground="#D9FFFFFF"/>
                    </StackPanel>
                </Border>

                <!-- 一卡通卡片 -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 卡片图标 -->
                        <Border Grid.Column="0" Width="100" Height="100" 
                                CornerRadius="16" 
                                Margin="0,0,28,0" VerticalAlignment="Top">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF6B35" Offset="0"/>
                                    <GradientStop Color="#FFD23F" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Width="48" Height="48" Data="{StaticResource CardIcon}"
                                  Fill="White" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- 信息区域 -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="校园一卡通" FontSize="22" FontWeight="Bold" 
                                      Foreground="#FF6B35" Margin="0,0,0,24"/>

                            <!-- 余额 -->
                            <StackPanel Margin="0,0,0,24">
                                <TextBlock Text="当前余额" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock x:Name="BalanceText" Text="--" 
                                          Style="{StaticResource InfoValueStyle}" 
                                          FontSize="32" Foreground="#27AE60"/>
                            </StackPanel>

                            <!-- 上次消费时间 -->
                            <StackPanel>
                                <TextBlock Text="上次消费时间" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock x:Name="LastConsumeText" Text="--" 
                                          Style="{StaticResource InfoValueStyle}" 
                                          FontSize="15" Foreground="#7F8C8D"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 操作按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Button x:Name="RefreshButton" 
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="24,12" FontSize="14"
                            Click="OnRefreshClick">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Path Width="16" Height="16" Data="{StaticResource RefreshIcon}"
                                      Fill="White" Stretch="Uniform" Margin="0,0,10,0"
                                      VerticalAlignment="Center"/>
                                <TextBlock Text="刷新信息" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <TextBlock x:Name="StatusText" Text="" 
                              FontSize="13" Foreground="#7F8C8D" 
                              VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>

                <!-- 提示信息 -->
                <Border Background="#E8F5E9" CornerRadius="8" Margin="24,0,24,24" Padding="20,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Path Width="18" Height="18" Data="{StaticResource LightbulbIcon}"
                                  Fill="#27AE60" Stretch="Uniform" Margin="0,0,10,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="使用提示" FontSize="14" FontWeight="SemiBold" 
                                      Foreground="#27AE60" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="• 余额信息实时更新，请定期查询" FontSize="12" 
                                  Foreground="#555555" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <TextBlock Text="• 如有余额异常，请及时联系校园卡管理中心" FontSize="12" 
                                  Foreground="#555555" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <TextBlock Text="• 校园卡可在食堂、超市、图书馆等场所使用" FontSize="12" 
                                  Foreground="#555555" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
