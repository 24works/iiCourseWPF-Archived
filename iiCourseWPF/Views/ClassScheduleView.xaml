<UserControl x:Class="iiCourseWPF.Views.ClassScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- 表头样式 -->
        <Style x:Key="HeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF6B35"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CornerRadius" Value="6,6,0,0"/>
        </Style>

        <!-- 单元格样式 -->
        <Style x:Key="CellStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <!-- 课程单元格样式 -->
        <Style x:Key="ClassCellStyle" TargetType="Border" BasedOn="{StaticResource CellStyle}">
            <Setter Property="Background" Value="#FFF5EB"/>
            <Setter Property="BorderBrush" Value="#FFE8D6"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#FFF8F0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 头部标题 -->
                <Border Style="{StaticResource PageHeaderStyle}">
                    <StackPanel>
                        <TextBlock Text="课程表" FontSize="26" FontWeight="Bold" 
                                  Foreground="White" Margin="0,0,0,6"/>
                        <TextBlock Text="查看您的课程安排" FontSize="13" 
                                  Foreground="#D9FFFFFF"/>
                    </StackPanel>
                </Border>

                <!-- 课程表网格 -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="24">
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 操作栏 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                            <Button x:Name="RefreshButton" 
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="20,10" FontSize="13"
                                    Click="OnRefreshClick">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="16" Height="16" Data="{StaticResource RefreshIcon}"
                                          Fill="White" Stretch="Uniform" Margin="0,0,8,0"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="刷新课程表" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock x:Name="StatusText" Text="" 
                                      FontSize="13" Foreground="#7F8C8D" 
                                      VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>

                        <!-- 课程表 -->
                        <Border Grid.Row="1" BorderBrush="#E8E8E8" BorderThickness="1" 
                                CornerRadius="8" Background="White">
                            <Grid x:Name="ScheduleGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- 表头 -->
                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource HeaderStyle}">
                                    <TextBlock Text="节次" FontSize="11" FontWeight="SemiBold" 
                                              Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource HeaderStyle}">
                                    <TextBlock Text="周一" FontSize="11" FontWeight="SemiBold" 
                                              Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource HeaderStyle}">
                                    <TextBlock Text="周二" FontSize="11" FontWeight="SemiBold" 
                                              Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="3" Style="{StaticResource HeaderStyle}">
                                    <TextBlock Text="周三" FontSize="11" FontWeight="SemiBold" 
                                              Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource HeaderStyle}">
                                    <TextBlock Text="周四" FontSize="11" FontWeight="SemiBold" 
                                              Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="5" Style="{StaticResource HeaderStyle}">
                                    <TextBlock Text="周五" FontSize="11" FontWeight="SemiBold" 
                                              Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="6" Style="{StaticResource HeaderStyle}">
                                    <TextBlock Text="周六" FontSize="11" FontWeight="SemiBold" 
                                              Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="7" Style="{StaticResource HeaderStyle}">
                                    <TextBlock Text="周日" FontSize="11" FontWeight="SemiBold" 
                                              Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- 节次标签 -->
                                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CellStyle}">
                                    <TextBlock Text="1" FontSize="11" TextAlignment="Center" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CellStyle}">
                                    <TextBlock Text="2" FontSize="11" TextAlignment="Center" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                </Border>
                                <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource CellStyle}">
                                    <TextBlock Text="3" FontSize="11" TextAlignment="Center" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                </Border>
                                <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource CellStyle}">
                                    <TextBlock Text="4" FontSize="11" TextAlignment="Center" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                </Border>
                                <Border Grid.Row="5" Grid.Column="0" Style="{StaticResource CellStyle}">
                                    <TextBlock Text="5" FontSize="11" TextAlignment="Center" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                </Border>
                                <Border Grid.Row="6" Grid.Column="0" Style="{StaticResource CellStyle}">
                                    <TextBlock Text="6" FontSize="11" TextAlignment="Center" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                </Border>
                                <Border Grid.Row="7" Grid.Column="0" Style="{StaticResource CellStyle}">
                                    <TextBlock Text="7" FontSize="11" TextAlignment="Center" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                </Border>
                                <Border Grid.Row="8" Grid.Column="0" Style="{StaticResource CellStyle}">
                                    <TextBlock Text="8" FontSize="11" TextAlignment="Center" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                </Border>
                                <Border Grid.Row="9" Grid.Column="0" Style="{StaticResource CellStyle}">
                                    <TextBlock Text="9" FontSize="11" TextAlignment="Center" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                </Border>
                                <Border Grid.Row="10" Grid.Column="0" Style="{StaticResource CellStyle}">
                                    <TextBlock Text="10" FontSize="11" TextAlignment="Center" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                </Border>
                                <Border Grid.Row="11" Grid.Column="0" Style="{StaticResource CellStyle}">
                                    <TextBlock Text="11" FontSize="11" TextAlignment="Center" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
