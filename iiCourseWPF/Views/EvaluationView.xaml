<UserControl x:Class="iiCourseWPF.Views.EvaluationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- 行样式 -->
        <Style x:Key="RowStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,12"/>
        </Style>

        <!-- 交替行样式 -->
        <Style x:Key="AlternateRowStyle" TargetType="Border" BasedOn="{StaticResource RowStyle}">
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundColor}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- 头部标题 -->
                <Border Style="{StaticResource PageHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="学生评教" FontSize="24" FontWeight="Bold" 
                                      Foreground="White" Margin="0,0,0,6"/>
                            <TextBlock Text="完成课程教学评价" FontSize="13" 
                                      Foreground="#D9FFFFFF"/>
                        </StackPanel>
                        <!-- 正在开发中提示 -->
                        <Border Grid.Column="1" Background="#FFE4E1" CornerRadius="6" 
                                Padding="12,8" VerticalAlignment="Center" Margin="0,0,20,0"
                                BorderBrush="#FF6B6B" BorderThickness="2">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="20" Height="20" Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M13,7H11V13H13V7M13,15H11V17H13V15Z"
                                      Fill="#FF6B6B" Stretch="Uniform" Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                                <TextBlock Text="正在开发中" FontSize="14" FontWeight="Bold" 
                                          Foreground="#FF6B6B" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- 操作区 -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="20,20,20,0">
                    <StackPanel>
                        <TextBlock Text="评教操作" FontSize="15" FontWeight="SemiBold" 
                                  Foreground="#2C3E50" Margin="0,0,0,14"/>

                        <!-- 评教功能暂时停用：因当前无评教任务，无法进行开发和测试，待有评教任务时恢复 -->
                        <WrapPanel Orientation="Horizontal">
                            <Button Command="{Binding LoadReviewsCommand}"
                                    IsEnabled="False"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="16,10" FontSize="13"
                                    Margin="0,0,10,8"
                                    Opacity="0.5">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="14" Height="14" Data="{StaticResource RefreshIcon}"
                                              Fill="White" Stretch="Uniform" Margin="0,0,6,0"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="加载评教列表" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <Button Command="{Binding FinishAllCommand}"
                                    IsEnabled="False"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="16,10" FontSize="13"
                                    Margin="0,0,0,8"
                                    Opacity="0.5">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="14" Height="14" Data="{StaticResource CheckIcon}"
                                              Fill="#FF6B35" Stretch="Uniform" Margin="0,0,6,0"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="一键完成评教" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </WrapPanel>

                        <TextBlock Text="{Binding StatusMessage}" 
                                  FontSize="12" Foreground="#7F8C8D" 
                                  Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 评教列表 -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="20,10,20,10">
                    <StackPanel>
                        <TextBlock Text="评教任务" FontSize="15" FontWeight="SemiBold" 
                                  Foreground="#2C3E50" Margin="0,0,0,14"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="380" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <!-- 空状态 -->
                                <Border Style="{StaticResource RowStyle}" 
                                        Visibility="{Binding HasData, Converter={StaticResource InverseBooleanConverter}}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Path Width="18" Height="18" Data="{StaticResource InfoIcon}"
                                              Fill="#7F8C8D" Stretch="Uniform" Margin="0,0,8,0"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="点击加载按钮查看评教任务" 
                                                  FontSize="12" Foreground="#7F8C8D" 
                                                  TextAlignment="Center" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- 评教列表 -->
                                <ItemsControl ItemsSource="{Binding Reviews}" 
                                             Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource RowStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding YearSemester}" 
                                                                  FontSize="12" FontWeight="SemiBold" 
                                                                  Foreground="#2C3E50"/>
                                                        <TextBlock Text="{Binding Category}" 
                                                                  FontSize="11" Foreground="#7F8C8D" 
                                                                  Margin="0,4,0,0"/>
                                                        <TextBlock Text="{Binding Batch}" 
                                                                  FontSize="11" Foreground="#7F8C8D"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" Background="{StaticResource TipBackgroundColor}" CornerRadius="4" 
                                                            Padding="8,4" VerticalAlignment="Center">
                                                        <TextBlock Text="待评教" FontSize="11" 
                                                                  Foreground="#27AE60" FontWeight="SemiBold"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- 提示信息 -->
                <Border Background="{StaticResource LightBackgroundColor}" CornerRadius="8" Margin="20,10,20,20" Padding="16,14" 
                        BorderBrush="#FFE8D6" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Path Width="16" Height="16" Data="{StaticResource WarningIcon}"
                                  Fill="#F39C12" Stretch="Uniform" Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="注意事项" FontSize="13" FontWeight="SemiBold" 
                                      Foreground="#F39C12" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="• 请认真对待评教，客观公正地评价教师教学" FontSize="11" 
                                  Foreground="#555555" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 一键评教功能会自动填写评教内容，建议手动检查" FontSize="11" 
                                  Foreground="#555555" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 评教完成后将无法修改，请谨慎操作" FontSize="11" 
                                  Foreground="#555555" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>