<UserControl x:Class="iiCourseWPF.Views.SpareClassroomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- 教室卡片样式 -->
        <Style x:Key="ClassroomCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FF6B35" Opacity="0.06" BlurRadius="10" ShadowDepth="1"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#FFF8F0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 头部标题 -->
                <Border Style="{StaticResource PageHeaderStyle}">
                    <StackPanel>
                        <TextBlock Text="空教室查询" FontSize="26" FontWeight="Bold" 
                                  Foreground="White" Margin="0,0,0,6"/>
                        <TextBlock Text="查找可用的空闲教室" FontSize="13" 
                                  Foreground="#D9FFFFFF"/>
                    </StackPanel>
                </Border>

                <!-- 查询控制区 -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="24,24,24,12">
                    <StackPanel>
                        <TextBlock Text="选择教学楼" FontSize="14" FontWeight="SemiBold" 
                                  Foreground="#2C3E50" Margin="0,0,0,12"/>

                        <WrapPanel Orientation="Horizontal">
                            <Button x:Name="Building1Button" 
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="20,10" FontSize="13"
                                    Click="OnBuildingClick" Tag="1"
                                    Margin="0,0,10,10">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="16" Height="16" Data="{StaticResource SchoolIcon}"
                                              Fill="#FF6B35" Stretch="Uniform" Margin="0,0,8,0"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="第一教学楼" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <Button x:Name="Building2Button" 
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="20,10" FontSize="13"
                                    Click="OnBuildingClick" Tag="2"
                                    Margin="0,0,10,10">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="16" Height="16" Data="{StaticResource SchoolIcon}"
                                              Fill="#FF6B35" Stretch="Uniform" Margin="0,0,8,0"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="第二教学楼" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <Button x:Name="Building3Button" 
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="20,10" FontSize="13"
                                    Click="OnBuildingClick" Tag="3"
                                    Margin="0,0,10,10">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="16" Height="16" Data="{StaticResource SchoolIcon}"
                                              Fill="#FF6B35" Stretch="Uniform" Margin="0,0,8,0"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="第三教学楼" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <Button x:Name="Building4Button" 
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="20,10" FontSize="13"
                                    Click="OnBuildingClick" Tag="4"
                                    Margin="0,0,10,10">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="16" Height="16" Data="{StaticResource SchoolIcon}"
                                              Fill="#FF6B35" Stretch="Uniform" Margin="0,0,8,0"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="第四教学楼" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </WrapPanel>

                        <TextBlock x:Name="StatusText" Text="" 
                                  FontSize="13" Foreground="#7F8C8D" 
                                  Margin="0,16,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 空教室列表 -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="24,12,24,24">
                    <StackPanel>
                        <TextBlock Text="空教室列表" FontSize="16" FontWeight="SemiBold" 
                                  Foreground="#2C3E50" Margin="0,0,0,16"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                            <WrapPanel x:Name="ClassroomPanel">
                                <!-- 空教室卡片将在这里动态生成 -->
                                <Border Style="{StaticResource ClassroomCardStyle}" 
                                        Background="#FFF8F0" Width="200">
                                    <StackPanel>
                                        <Path Width="36" Height="36" Data="{StaticResource RoomIcon}"
                                              Fill="#7F8C8D" Stretch="Uniform" Margin="0,0,0,12"
                                              HorizontalAlignment="Center"/>
                                        <TextBlock Text="请选择教学楼查询" 
                                                  FontSize="12" Foreground="#7F8C8D" 
                                                  TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
